---
import '../styles/global.css';
const { title } = Astro.props;
const siteUrl = 'https://thalux.ai';
const pageTitle = title ? `Thalux AI — ${title}` : 'Thalux AI';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Thalux AI — government data intelligence, business directories, and contract award analytics. Clean datasets for FinTech, GovCon, and healthcare sales teams." />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content="Raw government data, enriched and delivered. Skip the engineering — get the data that drives your pipeline." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl + Astro.url.pathname} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:image" content="https://thalux.ai/og-default.svg" />
    <meta name="twitter:image" content="https://thalux.ai/og-default.svg" />
    <link rel="canonical" href={siteUrl + Astro.url.pathname.replace(/\/$/, '')} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Thalux AI",
      "description": "Government data intelligence and contract award analytics. Clean datasets for sales teams.",
      "url": "https://thalux.ai",
      "priceRange": "$49-$499"
    })} />
  </head>
  <body class="bg-[#F5F4F0] text-[#2D2D2D] font-['Inter'] antialiased">
    <!-- Announcement Bar -->
    <div class="bg-[#E5B73C] text-white text-center text-sm font-medium py-3 px-6 tracking-wide">
      ✦ Government data, engineered for commerce ✦
    </div>

    <!-- Navigation -->
    <nav class="bg-white border-b border-[#DED8D0]">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
        <a href="/" class="font-['Manrope'] text-lg font-bold text-[#2D2D2D] tracking-tight">
          Thalux<span class="text-[#E5B73C]"> AI</span>
        </a>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium">
                  <a href="/" class="text-[#2D2D2D] hover:text-[#E5B73C] transition-colors">Home</a>
                  <a href="/data/govcon-intel" class="text-[#E5B73C] hover:text-[#CDA333] transition-colors font-semibold">GovCon</a>
                  <a href="/about" class="text-[#2D2D2D] hover:text-[#E5B73C] transition-colors">About</a>
                  <a href="/portal" class="text-[#2D2D2D] hover:text-[#E5B73C] transition-colors">Client Portal</a>
                  <a href="/contact" class="text-[#2D2D2D] hover:text-[#E5B73C] transition-colors">Contact</a>
                </div>
                <a href="/data/govcon-intel" class="bg-[#E5B73C] text-white px-5 py-2 rounded-md font-['Manrope'] font-bold text-sm hover:bg-[#CDA333] transition-colors">
                  Browse Data
                </a>
      </div>
    </nav>

    <!-- Page Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#2D2D2D] text-white">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid md:grid-cols-3 gap-10">
          <div>
            <div class="font-['Manrope'] text-xl font-bold mb-3">
              Thalux<span class="text-[#E5B73C]"> AI</span>
            </div>
            <p class="text-sm text-gray-400 leading-relaxed">
              Government data, engineered for commerce. Clean datasets delivered weekly.
            </p>
          </div>
          <div>
            <h4 class="font-['Manrope'] font-bold text-sm uppercase tracking-wider text-gray-400 mb-4">Data Products</h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="/data/govcon-intel" class="hover:text-[#E5B73C] transition-colors">GovCon Velocity</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-['Manrope'] font-bold text-sm uppercase tracking-wider text-gray-400 mb-4">Clients</h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="/portal" class="hover:text-[#E5B73C] transition-colors">Client Portal</a></li>
              <li><a href="/privacy" class="hover:text-[#E5B73C] transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="hover:text-[#E5B73C] transition-colors">Terms of Service</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-['Manrope'] font-bold text-sm uppercase tracking-wider text-gray-400 mb-4">Contact</h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li><a href="tel:+171****0566" class="hover:text-[#E5B73C] transition-colors">(717) 537-0566</a></li>
              <li>Lancaster County, PA</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-10 pt-6 text-sm text-gray-500 text-center">
          &copy; {new Date().getFullYear()} Thalux AI. No robots were harmed in the making of this site.
        </div>
      </div>
    </footer>
  </body>
</html>