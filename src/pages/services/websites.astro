---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Website Builds">
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <div class="mb-8">
      <a href="/services" class="text-[#E5B73C] text-sm font-semibold hover:underline">← All Services</a>
    </div>

    <h1 class="font-['Manrope'] text-4xl md:text-5xl font-extrabold text-[#2D2D2D] mb-4 tracking-tight">
      Website Builds
    </h1>
    <p class="text-lg text-[#333333] mb-10 max-w-2xl">
      A real website — not a template. Mobile-first, built for local search, with tracking so you know exactly where your leads come from.
    </p>

    <div class="bg-white rounded-xl border border-[#DED8D0] p-8 mb-10">
      <h2 class="font-['Manrope'] text-2xl font-bold mb-4">What you get</h2>
      <ul class="space-y-4">
        <li class="flex gap-3">
          <span class="text-[#E5B73C] shrink-0 mt-0.5">✓</span>
          <div>
            <strong class="font-['Manrope'] font-bold">Mobile-first design</strong>
            <p class="text-sm text-[#333333]">Built for the phone in your pocket. Your customer searches on their phone, your site loads fast and looks right.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-[#E5B73C] shrink-0 mt-0.5">✓</span>
          <div>
            <strong class="font-['Manrope'] font-bold">SEO foundation</strong>
            <p class="text-sm text-[#333333]">Title tags, meta descriptions, local schema — everything Google needs to show your site to people searching in your area.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-[#E5B73C] shrink-0 mt-0.5">✓</span>
          <div>
            <strong class="font-['Manrope'] font-bold">Contact form with tracking</strong>
            <p class="text-sm text-[#333333]">Every form submission is tracked. You know who inquired, when, and from which page.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-[#E5B73C] shrink-0 mt-0.5">✓</span>
          <div>
            <strong class="font-['Manrope'] font-bold">Call tracking ready</strong>
            <p class="text-sm text-[#333333]">Your business phone number displayed prominently. We track which pages and campaigns drive calls.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-[#E5B73C] shrink-0 mt-0.5">✓</span>
          <div>
            <strong class="font-['Manrope'] font-bold">AI receptionist embed</strong>
            <p class="text-sm text-[#333333]">Your website and phone system work together. The AI answers calls, the site generates them.</p>
          </div>
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-xl border border-[#DED8D0] p-8 mb-10">
      <h2 class="font-['Manrope'] text-2xl font-bold mb-4">Pricing</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="border border-[#DED8D0] rounded-lg p-6">
          <div class="font-['Manrope'] font-bold text-lg mb-1">Single Page</div>
          <div class="font-['Manrope'] text-3xl font-extrabold mb-2">$349</div>
          <div class="text-sm text-[#333333]">One-time build. Perfect for getting started.</div>
        </div>
        <div class="border border-[#DED8D0] rounded-lg p-6">
          <div class="font-['Manrope'] font-bold text-lg mb-1">Multi-Page</div>
          <div class="font-['Manrope'] text-3xl font-extrabold mb-2">$500+</div>
          <div class="text-sm text-[#333333]">Custom scope — home, services, about, contact, and more.</div>
        </div>
      </div>
      <div class="mt-4 p-4 bg-[rgba(229,183,60,0.08)] rounded-lg border border-[#E5B73C]">
        <p class="text-sm text-[#333333]"><strong class="font-['Manrope'] font-bold">Bronze Retainer ($195/mo):</strong> Website maintenance + GBP management + social + Facebook. Everything stays working and updated.</p>
      </div>
    </div>

    <div class="text-center">
      <a href="/contact" class="inline-block bg-[#E5B73C] text-white px-8 py-4 rounded-md font-['Manrope'] font-bold text-base hover:bg-[#CDA333] transition-colors">
        Start Your Site
      </a>
    </div>
  </section>
</Layout>