---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI Voice Receptionist">
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <div class="mb-8">
      <a href="/services" class="text-[#E5B73C] text-sm font-semibold hover:underline">← All Services</a>
    </div>

    <h1 class="font-['Manrope'] text-4xl md:text-5xl font-extrabold text-[#2D2D2D] mb-4 tracking-tight">
      AI Voice Receptionist
    </h1>
    <p class="text-lg text-[#333333] mb-10 max-w-2xl">
      Never miss a lead because you were under a car, on a roof, or in a crawl space. Your AI receptionist answers 24/7, screens callers, and books appointments. You keep working.
    </p>

    <div class="bg-white rounded-xl border border-[#DED8D0] p-8 mb-10">
      <h2 class="font-['Manrope'] text-2xl font-bold mb-4">How it works</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0">01</span>
          <div>
            <h3 class="font-['Manrope'] font-bold">Customer calls your number</h3>
            <p class="text-sm text-[#333333]">Your existing number forwards to the AI receptionist. No new number to publish.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0">02</span>
          <div>
            <h3 class="font-['Manrope'] font-bold">AI answers naturally</h3>
            <p class="text-sm text-[#333333]">Real conversation — not a phone tree. The AI asks questions, qualifies the lead, and takes the right action.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0">03</span>
          <div>
            <h3 class="font-['Manrope'] font-bold">You get the details</h3>
            <p class="text-sm text-[#333333]">Every call is logged. You get a summary — who called, what they wanted, and whether a follow-up is needed.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0">04</span>
          <div>
            <h3 class="font-['Manrope'] font-bold">Emergency? No problem</h3>
            <p class="text-sm text-[#333333]">The AI recognizes urgent calls and can forward them directly to your cell. You never miss a real emergency.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-[#DED8D0] p-8 mb-10">
      <h2 class="font-['Manrope'] text-2xl font-bold mb-4">Pricing</h2>
      <div class="bg-[rgba(229,183,60,0.08)] border border-[#E5B73C] rounded-lg p-6 mb-4">
        <div class="text-sm text-[#333333] mb-1">Early adopter pricing</div>
        <div class="font-['Manrope'] text-3xl font-extrabold text-[#2D2D2D]">+$54<span class="text-base font-normal text-[#333333]">/mo</span></div>
        <div class="text-sm text-[#333333] mt-1">Added to your Bronze website retainer. Voice agent demo required before adding.</div>
      </div>
    </div>

    <div class="text-center">
      <a href="/contact" class="inline-block bg-[#E5B73C] text-white px-8 py-4 rounded-md font-['Manrope'] font-bold text-base hover:bg-[#CDA333] transition-colors">
        Talk to Us
      </a>
    </div>
  </section>
</Layout>