---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Services">
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <h1 class="font-['Manrope'] text-4xl md:text-5xl font-extrabold text-[#2D2D2D] mb-4 tracking-tight">
      Our Services
    </h1>
    <p class="text-[#333333] text-lg max-w-xl mb-12">
      Three systems. One goal: make sure every person looking for your service finds you, reaches you, and becomes a customer.
    </p>

    <div class="space-y-8">
      <!-- Card: Voice Agent -->
      <a href="/services/voice-agents" class="block bg-white rounded-xl border border-[#DED8D0] p-8 hover:border-[#E5B73C] transition-colors group">
        <div class="md:flex md:items-start md:gap-8">
          <div class="w-14 h-14 rounded-xl bg-[rgba(229,183,60,0.12)] flex items-center justify-center mb-4 md:mb-0 shrink-0">
            <span class="text-2xl">🎙️</span>
          </div>
          <div class="flex-1">
            <h2 class="font-['Manrope'] text-2xl font-bold text-[#2D2D2D] mb-2 group-hover:text-[#E5B73C] transition-colors">AI Voice Receptionist</h2>
            <p class="text-[#333333] mb-3">24/7 phone answering that screens, qualifies, and books — so you never miss a lead while you're working.</p>
            <span class="text-[#E5B73C] font-semibold text-sm">Learn more →</span>
          </div>
        </div>
      </a>

      <!-- Card: Websites -->
      <a href="/services/websites" class="block bg-white rounded-xl border border-[#DED8D0] p-8 hover:border-[#E5B73C] transition-colors group">
        <div class="md:flex md:items-start md:gap-8">
          <div class="w-14 h-14 rounded-xl bg-[rgba(229,183,60,0.12)] flex items-center justify-center mb-4 md:mb-0 shrink-0">
            <span class="text-2xl">🌐</span>
          </div>
          <div class="flex-1">
            <h2 class="font-['Manrope'] text-2xl font-bold text-[#2D2D2D] mb-2 group-hover:text-[#E5B73C] transition-colors">Website Builds</h2>
            <p class="text-[#333333] mb-3">A real website — not a template. Mobile-first, SEO-optimized, with tracking so you know what's working.</p>
            <span class="text-[#E5B73C] font-semibold text-sm">Learn more →</span>
          </div>
        </div>
      </a>

      <!-- Card: GBP -->
      <a href="/services/gbp" class="block bg-white rounded-xl border border-[#DED8D0] p-8 hover:border-[#E5B73C] transition-colors group">
        <div class="md:flex md:items-start md:gap-8">
          <div class="w-14 h-14 rounded-xl bg-[rgba(229,183,60,0.12)] flex items-center justify-center mb-4 md:mb-0 shrink-0">
            <span class="text-2xl">📍</span>
          </div>
          <div class="flex-1">
            <h2 class="font-['Manrope'] text-2xl font-bold text-[#2D2D2D] mb-2 group-hover:text-[#E5B73C] transition-colors">GBP Optimization</h2>
            <p class="text-[#333333] mb-3">Google Business Profile that actually ranks. Complete audit, optimization, and ongoing management.</p>
            <span class="text-[#E5B73C] font-semibold text-sm">Learn more →</span>
          </div>
        </div>
      </a>
    </div>
  </section>
</Layout>