---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message Sent">
  <section class="max-w-2xl mx-auto px-6 py-20 text-center">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <span class="text-green-600 text-3xl">&#10003;</span>
    </div>
    <h1 class="font-['Manrope'] text-3xl font-extrabold text-[#2D2D2D] mb-4">Thanks for reaching out</h1>
    <p class="text-[#666] mb-8 max-w-md mx-auto">
      We'll review your message and get back to you within one business day.
      In the meantime, feel free to call <a href="tel:+171****0566" class="text-[#E5B73C] underline">(717) 537-0566</a>.
    </p>
    <a href="/" class="inline-block bg-[#E5B73C] text-white px-8 py-4 rounded-md font-['Manrope'] font-bold hover:bg-[#CDA333] transition-colors">
      Back to Home
    </a>
  </section>
</Layout>