---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <h1 class="font-['Manrope'] text-4xl md:text-5xl font-extrabold text-[#2D2D2D] mb-4 tracking-tight">
      See if We're a Fit
    </h1>
    <p class="text-lg text-[#333333] mb-10 max-w-xl">
      No pressure. No sales pitch. A 15-minute call to see if we can help. If we can't, we'll tell you straight up.
    </p>

    <div class="grid md:grid-cols-2 gap-10">
      <!-- Contact Form -->
      <div class="bg-white rounded-xl border border-[#DED8D0] p-8">
        <h2 class="font-['Manrope'] text-xl font-bold mb-6">Send us a message</h2>
        <form action="/thank-you" method="POST" netlify data-netlify="true" name="contact" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-[#333333] mb-1">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-md border border-[#DED8D0] bg-[#F5F4F0] text-[#2D2D2D] text-sm focus:outline-none focus:border-[#E5B73C] focus:ring-1 focus:ring-[#E5B73C]" placeholder="Your name" />
          </div>
          <div>
            <label for="business" class="block text-sm font-medium text-[#333333] mb-1">Business name</label>
            <input type="text" id="business" name="business" class="w-full px-4 py-3 rounded-md border border-[#DED8D0] bg-[#F5F4F0] text-[#2D2D2D] text-sm focus:outline-none focus:border-[#E5B73C] focus:ring-1 focus:ring-[#E5B73C]" placeholder="Your shop name" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-[#333333] mb-1">Phone</label>
            <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-md border border-[#DED8D0] bg-[#F5F4F0] text-[#2D2D2D] text-sm focus:outline-none focus:border-[#E5B73C] focus:ring-1 focus:ring-[#E5B73C]" placeholder="(717) 555-0123" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-[#333333] mb-1">What do you need?</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-md border border-[#DED8D0] bg-[#F5F4F0] text-[#2D2D2D] text-sm focus:outline-none focus:border-[#E5B73C] focus:ring-1 focus:ring-[#E5B73C]" placeholder="Tell us about your shop and what you're looking for..."></textarea>
          </div>
          <button type="submit" class="w-full bg-[#E5B73C] text-white py-3 rounded-md font-['Manrope'] font-bold text-sm hover:bg-[#CDA333] transition-colors">
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div>
        <div class="bg-white rounded-xl border border-[#DED8D0] p-8 mb-6">
          <h2 class="font-['Manrope'] text-xl font-bold mb-4">Call us</h2>
          <a href="tel:+171****0566" class="text-2xl font-['Manrope'] font-extrabold text-[#2D2D2D] hover:text-[#E5B73C] transition-colors">
            (717) 537-0566
          </a>
          <p class="text-sm text-[#333333] mt-2">Leave a message. The AI receptionist will answer.</p>
        </div>

        <div class="bg-white rounded-xl border border-[#DED8D0] p-8">
          <h2 class="font-['Manrope'] text-xl font-bold mb-4">What happens next?</h2>
          <div class="space-y-4">
            <div class="flex gap-3">
              <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0 text-sm">01</span>
              <div>
                <p class="text-sm text-[#333333]">We hop on a 15-minute call to understand your business and what you're struggling with.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0 text-sm">02</span>
              <div>
                <p class="text-sm text-[#333333]">If we think we can help, we'll propose a system tailored to your shop.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <span class="text-[#E5B73C] font-['Manrope'] font-extrabold shrink-0 text-sm">03</span>
              <div>
                <p class="text-sm text-[#333333]">If we can't help you, we'll tell you honestly. No upsells. No pitch.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>