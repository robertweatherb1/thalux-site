---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="GovCon Velocity — Federal Contract Award Data">
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-12">
    <div class="md:grid md:grid-cols-2 md:gap-16 items-start">
      <div>
        <div class="flex flex-wrap gap-2 mb-5">
          <span class="inline-block bg-[rgba(229,183,60,0.12)] text-[#E5B73C] font-['Manrope'] font-bold text-xs px-4 py-2 rounded-full uppercase tracking-wider">
            ⚡ Data Product
          </span>
          <span class="inline-block bg-[rgba(220,38,38,0.12)] text-[#DC2626] font-['Manrope'] font-bold text-xs px-4 py-2 rounded-full uppercase tracking-wider">
            ATOM Retirement Jul 31, 2026
          </span>
        </div>
        <h1 class="font-['Manrope'] text-4xl md:text-5xl font-extrabold leading-tight tracking-tight text-[#2D2D2D] mb-4">
          Thalux <span class="text-[#E5B73C]">GovCon Velocity</span><br />
          Contract Award Intelligence
        </h1>
        <p class="text-[#333] text-lg leading-relaxed mb-4">
          Weekly NAICS-segmented CSV drop-feed of every federal contract award, modification, and sub-award exceeding the micro-purchase threshold. Pre-scrubbed from the SAM.gov Contract Awards API — no engineering wrapper required.
        </p>
        <p class="text-sm text-[#666] leading-relaxed">
          FPDS.gov was decommissioned February 24, 2026. The legacy ATOM feed retires July 31, 2026. Contractors who relied on automated feeds now face a fractured data landscape — every NAICS code, every award, delivered to your inbox Monday morning.
        </p>
      </div>
      <div class="mt-8 md:mt-0">
        <!-- Metrics -->
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="bg-white border border-[#DED8D0] rounded-xl p-5 text-center">
            <div class="font-['Manrope'] font-extrabold text-3xl text-[#E5B73C]">1M+</div>
            <div class="text-xs text-[#666] mt-1">Awards Indexed</div>
          </div>
          <div class="bg-white border border-[#DED8D0] rounded-xl p-5 text-center">
            <div class="font-['Manrope'] font-extrabold text-3xl text-[#E5B73C]">19</div>
            <div class="text-xs text-[#666] mt-1">Data Columns</div>
          </div>
          <div class="bg-white border border-[#DED8D0] rounded-xl p-5 text-center">
            <div class="font-['Manrope'] font-extrabold text-3xl text-[#E5B73C]">900+</div>
            <div class="text-xs text-[#666] mt-1">NAICS Codes</div>
          </div>
          <div class="bg-white border border-[#DED8D0] rounded-xl p-5 text-center">
            <div class="font-['Manrope'] font-extrabold text-3xl text-[#E5B73C]">Weekly</div>
            <div class="text-xs text-[#666] mt-1">Refresh Cadence</div>
          </div>
        </div>
        <p class="text-xs text-[#999] text-center">Data sourced from SAM.gov Contract Awards API (open.gsa.gov). Enriched by Thalux AI inference engine.</p>
      </div>
    </div>
  </section>

  <!-- Friction Comparison -->
  <section class="bg-white py-16 border-t border-b border-[#DED8D0]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-['Manrope'] text-3xl font-bold text-[#2D2D2D] text-center mb-10">The Federal Data Gap</h2>
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="border border-[#DED8D0] rounded-xl p-8 bg-white">
          <h3 class="font-['Manrope'] font-bold text-lg text-[#2D2D2D] mb-3">🧩 The Old Way</h3>
          <ul class="space-y-3 text-sm text-[#666]">
            <li class="flex items-start gap-2"><span class="text-[#DED8D0] shrink-0">•</span> Maintain custom REST API wrappers for SAM.gov</li>
            <li class="flex items-start gap-2"><span class="text-[#DED8D0] shrink-0">•</span> Paginate 400K+ records with rate-limited keys</li>
            <li class="flex items-start gap-2"><span class="text-[#DED8D0] shrink-0">•</span> Manually parse nested JSON into usable CSVs</li>
            <li class="flex items-start gap-2"><span class="text-[#DED8D0] shrink-0">•</span> No change tracking across extraction runs</li>
            <li class="flex items-start gap-2 font-semibold text-[#2D2D2D]"><span class="text-[#E5B73C] shrink-0">→</span> Estimated: 40+ hrs / month of engineering overhead</li>
          </ul>
        </div>
        <div class="border-2 border-[#E5B73C] rounded-xl p-8 bg-white shadow-sm">
          <h3 class="font-['Manrope'] font-bold text-lg text-[#2D2D2D] mb-3">⚡ GovCon Velocity</h3>
          <ul class="space-y-3 text-sm text-[#666]">
            <li class="flex items-start gap-2"><span class="text-[#10B981] shrink-0">✓</span> Pre-scrubbed from SAM.gov Contract Awards API</li>
            <li class="flex items-start gap-2"><span class="text-[#10B981] shrink-0">✓</span> NAICS-segmented — your codes, your data</li>
            <li class="flex items-start gap-2"><span class="text-[#10B981] shrink-0">✓</span> Flat CSV — no nested JSON to parse</li>
            <li class="flex items-start gap-2"><span class="text-[#10B981] shrink-0">✓</span> Weekly automated email delivery</li>
            <li class="flex items-start gap-2 font-semibold text-[#2D2D2D]"><span class="text-[#E5B73C] shrink-0">→</span> Your cost: one weekly CSV download, zero engineering</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Schema Table -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-['Manrope'] text-3xl font-bold text-[#2D2D2D] mb-2">Exact Schema (19 columns)</h2>
      <p class="text-[#666] mb-8">Every award, modification, and sub-award exceeding the micro-purchase threshold within your target NAICS footprint. Delivered as flat CSV.</p>
      <div class="overflow-x-auto">
        <table class="w-full bg-white border border-[#DED8D0] rounded-xl overflow-hidden">
          <thead>
            <tr class="bg-[#2D2D2D] text-white">
              <th class="text-left py-3 px-4 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Column</th>
              <th class="text-left py-3 px-4 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Description</th>
              <th class="text-left py-3 px-4 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Example</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">award_id</td><td class="py-3 px-4 text-sm text-[#333]">Unique award identifier</td><td class="py-3 px-4 text-sm text-[#666]">CON-AWD-2026-04712</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">piid</td><td class="py-3 px-4 text-sm text-[#333]">Procurement Instrument Identifier</td><td class="py-3 px-4 text-sm text-[#666]">W912P5-26-C-0012</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">agency_name</td><td class="py-3 px-4 text-sm text-[#333]">Contracting agency name</td><td class="py-3 px-4 text-sm text-[#666]">U.S. Army Corps of Engineers</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">naics_code</td><td class="py-3 px-4 text-sm text-[#333]">6-digit NAICS code</td><td class="py-3 px-4 text-sm text-[#666]">541511</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">naics_description</td><td class="py-3 px-4 text-sm text-[#333]">NAICS industry description</td><td class="py-3 px-4 text-sm text-[#666]">Custom Computer Programming Services</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">date_signed</td><td class="py-3 px-4 text-sm text-[#333]">Contract award date</td><td class="py-3 px-4 text-sm text-[#666]">2026-06-15</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">dollars_obligated</td><td class="py-3 px-4 text-sm text-[#333]">Amount obligated on this action</td><td class="py-3 px-4 text-sm text-[#666]">$2,450,000</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">total_contract_value</td><td class="py-3 px-4 text-sm text-[#333]">Base + all options value</td><td class="py-3 px-4 text-sm text-[#666]">$12,400,000</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">awardee_name</td><td class="py-3 px-4 text-sm text-[#333]">Prime awardee legal name</td><td class="py-3 px-4 text-sm text-[#666]">Booz Allen Hamilton Inc.</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">awardee_uei</td><td class="py-3 px-4 text-sm text-[#333]">Unique Entity Identifier (SAM)</td><td class="py-3 px-4 text-sm text-[#666]">F3V5KJQ7N8M1</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">awardee_state</td><td class="py-3 px-4 text-sm text-[#333]">Awardee headquarters state</td><td class="py-3 px-4 text-sm text-[#666]">VA</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">pop_state_code</td><td class="py-3 px-4 text-sm text-[#333]">Place of performance state</td><td class="py-3 px-4 text-sm text-[#666]">CA</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">contract_action_type</td><td class="py-3 px-4 text-sm text-[#333]">Type of contract action</td><td class="py-3 px-4 text-sm text-[#666]">Definitive Contract</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">competition_status</td><td class="py-3 px-4 text-sm text-[#333]">Competed or not</td><td class="py-3 px-4 text-sm text-[#666]">Competitive</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">set_aside_description</td><td class="py-3 px-4 text-sm text-[#333]">Small business set-aside type</td><td class="py-3 px-4 text-sm text-[#666]">Service-Disabled Veteran-Owned</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">number_of_offers</td><td class="py-3 px-4 text-sm text-[#333]">Offers received</td><td class="py-3 px-4 text-sm text-[#666]">3</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">small_business_flag</td><td class="py-3 px-4 text-sm text-[#333]">Small business award indicator</td><td class="py-3 px-4 text-sm text-[#666]">TRUE</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">fiscal_year</td><td class="py-3 px-4 text-sm text-[#333]">Federal fiscal year</td><td class="py-3 px-4 text-sm text-[#666]">2026</td></tr>
            <tr><td class="py-3 px-4 font-['Manrope'] font-semibold text-sm">extracted_at</td><td class="py-3 px-4 text-sm text-[#333]">ISO 8601 extraction timestamp</td><td class="py-3 px-4 text-sm text-[#666]">2026-07-01T12:15:00Z</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Sample Records (blurred preview) -->
  <section class="bg-white py-16 border-t border-b border-[#DED8D0]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-['Manrope'] text-3xl font-bold text-[#2D2D2D] mb-2">Sample Records</h2>
      <p class="text-[#666] mb-8">5 sample records shown below. Full dataset covers 900+ NAICS codes with 1M+ indexed awards.</p>
      <div class="overflow-x-auto rounded-xl border border-[#DED8D0] bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#2D2D2D] text-white">
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">PIID</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">NAICS</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Agency</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Awardee</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Value</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">Date</th>
              <th class="text-left py-3 px-3 font-['Manrope'] font-semibold text-xs uppercase tracking-wider">State</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-3 font-['Manrope'] font-semibold text-sm text-[#E5B73C]">W912P5-26-C-0012</td><td class="py-3 px-3 text-sm text-[#333]">541511</td><td class="py-3 px-3 text-sm text-[#333]">USACE</td><td class="py-3 px-3 text-sm text-[#333]">Booz Allen Hamilton</td><td class="py-3 px-3 text-sm text-[#333]">$2.45M</td><td class="py-3 px-3 text-sm text-[#333]">2026-06-15</td><td class="py-3 px-3 text-sm text-[#E5B73C]">VA</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-3 font-['Manrope'] font-semibold text-sm text-[#E5B73C]">FA8750-26-C-0047</td><td class="py-3 px-3 text-sm text-[#333]">541712</td><td class="py-3 px-3 text-sm text-[#333]">USAF</td><td class="py-3 px-3 text-sm text-[#333]">SAIC</td><td class="py-3 px-3 text-sm text-[#333]">$8.10M</td><td class="py-3 px-3 text-sm text-[#333]">2026-06-12</td><td class="py-3 px-3 text-sm text-[#E5B73C]">FL</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-3 font-['Manrope'] font-semibold text-sm text-[#E5B73C]">GS00Q-26-OSD-001</td><td class="py-3 px-3 text-sm text-[#333]">541519</td><td class="py-3 px-3 text-sm text-[#333]">GSA</td><td class="py-3 px-3 text-sm text-[#333]">Deloitte Consulting</td><td class="py-3 px-3 text-sm text-[#333]">$22.50M</td><td class="py-3 px-3 text-sm text-[#333]">2026-06-01</td><td class="py-3 px-3 text-sm text-[#E5B73C]">DC</td></tr>
            <tr class="border-b border-[#DED8D0] bg-[#FAFAF8]"><td class="py-3 px-3 font-['Manrope'] font-semibold text-sm text-[#E5B73C]">N00189-26-C-0312</td><td class="py-3 px-3 text-sm text-[#333]">336611</td><td class="py-3 px-3 text-sm text-[#333]">NAVSEA</td><td class="py-3 px-3 text-sm text-[#333]">HII Inc.</td><td class="py-3 px-3 text-sm text-[#333]">$47.20M</td><td class="py-3 px-3 text-sm text-[#333]">2026-05-28</td><td class="py-3 px-3 text-sm text-[#E5B73C]">VA</td></tr>
            <tr class="border-b border-[#DED8D0]"><td class="py-3 px-3 font-['Manrope'] font-semibold text-sm text-[#E5B73C]">75FCMC-26-C-0023</td><td class="py-3 px-3 text-sm text-[#333]">621111</td><td class="py-3 px-3 text-sm text-[#333]">HHS</td><td class="py-3 px-3 text-sm text-[#333]">Leidos Health</td><td class="py-3 px-3 text-sm text-[#333]">$1.85M</td><td class="py-3 px-3 text-sm text-[#333]">2026-05-15</td><td class="py-3 px-3 text-sm text-[#E5B73C]">MD</td></tr>
            <!-- Blur overlay rows -->
            <tr class="relative"><td colspan="7" class="relative overflow-hidden"><div class="absolute inset-0 z-10" style="backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"></div><div class="opacity-15 py-3 px-3 flex items-center gap-4 text-sm"><span class="font-['Manrope'] font-semibold text-[#E5B73C]">N00189-26-C-0500</span><span class="text-[#333]">334118</span><span class="text-[#333]">DON</span><span class="text-[#333]">Raytheon</span><span class="text-[#333]">$94.1M</span><span class="text-[#333]">2026-07-10</span><span class="text-[#E5B73C]">CA</span></div></td></tr>
            <tr class="relative"><td colspan="7" class="relative overflow-hidden"><div class="absolute inset-0 z-10" style="backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"></div><div class="opacity-15 py-3 px-3 flex items-center gap-4 text-sm"><span class="font-['Manrope'] font-semibold text-[#E5B73C]">W52P1J-26-C-0501</span><span class="text-[#333]">332312</span><span class="text-[#333]">DLA</span><span class="text-[#333]">Lockheed Martin</span><span class="text-[#333]">$67.3M</span><span class="text-[#333]">2026-07-08</span><span class="text-[#E5B73C]">PA</span></div></td></tr>
          </tbody>
        </table>
        <div class="text-center py-4 bg-gradient-to-t from-[#FAFAF8] to-white">
          <span class="text-[#999] text-sm">+ 1M+ additional awards spanning 900+ NAICS codes across 80+ agencies</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing: 3-tier subscription -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-['Manrope'] text-3xl font-bold text-[#2D2D2D] text-center mb-2">Choose Your Plan</h2>
      <p class="text-[#666] text-center max-w-lg mx-auto mb-10">The ATOM feed dies July 31. Don't lose your competitive intelligence pipeline.</p>
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Single NAICS -->
        <div class="bg-white border border-[#DED8D0] rounded-xl p-8 hover:border-[#E5B73C] transition-colors">
          <div class="font-['Manrope'] font-bold text-lg text-[#2D2D2D] mb-2">GovCon Velocity</div>
          <div class="font-['Manrope'] font-bold text-sm text-[#E5B73C] uppercase tracking-wide mb-1">Single NAICS</div>
          <div class="font-['Manrope'] font-extrabold text-4xl text-[#2D2D2D] mb-1">$199 <span class="text-base font-medium text-[#666]">USD</span></div>
          <div class="text-sm text-[#666] mb-6">per month</div>
          <ul class="space-y-3 mb-8 text-sm">
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> One NAICS code tracked</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Weekly CSV email delivery</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> All contract actions & mods</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Single commercial license</li>
          </ul>
          <button onclick="checkout('govcon_velocity_single')"
             class="checkout-btn w-full bg-[#E5B73C] text-white py-4 rounded-md font-['Manrope'] font-bold text-base hover:bg-[#CDA333] transition-colors text-center cursor-pointer border-0">
            Subscribe — $199/mo
          </button>
        </div>
        <!-- Multi NAICS (Featured) -->
        <div class="bg-white border-2 border-[#E5B73C] rounded-xl p-8 shadow-sm scale-[1.02]">
          <div class="font-['Manrope'] font-bold text-lg text-[#2D2D2D] mb-2">GovCon Velocity</div>
          <div class="font-['Manrope'] font-bold text-sm text-[#E5B73C] uppercase tracking-wide mb-1">Multi NAICS</div>
          <div class="font-['Manrope'] font-extrabold text-4xl text-[#2D2D2D] mb-1">$349 <span class="text-base font-medium text-[#666]">USD</span></div>
          <div class="text-sm text-[#666] mb-6">per month</div>
          <ul class="space-y-3 mb-8 text-sm">
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Up to 5 NAICS codes</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Weekly CSV email delivery</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Full modification tracking</li>
            <li class="flex items-center gap-2 text-[#333]"><span class="text-[#E5B73C] font-bold">✓</span> Competitive intelligence view</li>
          </ul>
          <button onclick="checkout('govcon_velocity_multi')"
             class="checkout-btn w-full bg-[#E5B73C] text-white py-4 rounded-md font-['Manrope'] font-bold text-base hover:bg-[#CDA333] transition-colors text-center cursor-pointer border-0">
            Subscribe — $349/mo
          </button>
        </div>
        <!-- Enterprise -->
        <div class="bg-white border border-[#DED8D0] rounded-xl p-8 hover:border-[#E5B73C] transition-colors">
          <div class="font-['Manrope'] font-bold text-lg text-[#2D2D2D] mb-2">GovCon Velocity</div>
          <div class="font-['Manrope'] font-bold text-sm text-[#E5B73C] uppercase tracking-wide mb-1">Enterprise</div>
          <div class="font-['Manrope'] font-extrabold text-4xl text-[#2D2D2D] mb-1">$499 <span class="text-base font-medium text-[#666]">USD</span></div>
