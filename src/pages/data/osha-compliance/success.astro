---
import Layout from '../../../layouts/Layout.astro';
const productSlug = 'osha-compliance';
const productName = 'OSHA Compliance — 300 Log & Injury Data';
---

<Layout title="Purchase Complete — OSHA Compliance | Thalux AI">
  <meta name="robots" content="noindex, nofollow" />
  <main class="min-h-screen flex items-center justify-center px-6 py-20">
    <div class="max-w-lg w-full text-center">
      <div class="w-20 h-20 bg-green-500/10 border border-green-500/30 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <h1 class="font-['Manrope'] text-3xl md:text-4xl font-bold text-[#2D2D2D] mb-4">
        Purchase Complete!
      </h1>
      <p class="text-lg text-[#666] leading-relaxed mb-8">
        Your <strong class="text-[#2D2D2D]">{productName}</strong> order is being processed.
      </p>

      <div class="bg-white border border-[#DED8D0] rounded-xl p-6 mb-8 text-left">
        <h2 class="font-['Manrope'] font-bold text-[#2D2D2D] mb-3">📬 What happens next?</h2>
        <ol class="text-sm text-[#666] space-y-3">
          <li class="flex gap-3"><span class="text-[#E5B73C] font-bold shrink-0">1.</span><span>Check your email inbox.</span></li>
          <li class="flex gap-3"><span class="text-[#E5B73C] font-bold shrink-0">2.</span><span>You'll receive an email with a download link.</span></li>
          <li class="flex gap-3"><span class="text-[#E5B73C] font-bold shrink-0">3.</span><span>Click the link within 24 hours to download your CSV.</span></li>
          <li class="flex gap-3"><span class="text-[#E5B73C] font-bold shrink-0">4.</span><span>Start benchmarking your safety program! 🚀</span></li>
        </ol>
      </div>

      <div class="bg-amber-500/5 border border-amber-500/20 rounded-xl p-4 mb-8">
        <p class="text-sm text-[#E5B73C]">
          ⏱️ <strong>Didn't receive an email?</strong> Check spam or contact
          <a href="mailto:support@thalux.ai" class="underline">support@thalux.ai</a>
        </p>
      </div>

      <a href={`/data/${productSlug}`} class="inline-block text-sm text-[#999] hover:text-[#666] transition-colors">← Back to product page</a>
    </div>
  </main>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const sessionId = urlParams.get('session_id');
    if (sessionId) console.log('Stripe session completed:', sessionId);
  </script>
</Layout>