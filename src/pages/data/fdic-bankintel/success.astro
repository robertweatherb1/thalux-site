---
// FDIC BankIntel — Purchase Success Page
// Shown after successful Stripe checkout
import '../../../styles/global.css';
import Footer from '../../../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Purchase Complete — FDIC B2B Dataset | Thalux AI</title>
    <meta name="description" content="Your FDIC Premium B2B Sales Dataset purchase is processing. Check your email for the download link." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://thalux.ai/data/fdic-bankintel/success" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0A0A0A] text-gray-200 font-body">
    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="max-w-lg w-full text-center">
        <!-- Success icon -->
        <div class="w-20 h-20 bg-green-500/10 border border-green-500/30 rounded-full flex items-center justify-center mx-auto mb-8">
          <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>

        <h1 class="text-3xl md:text-4xl font-headline font-bold text-white mb-4">
          Purchase Complete!
        </h1>
        <p class="text-lg text-gray-400 font-body leading-relaxed mb-8">
          Your <strong class="text-white">FDIC Premium B2B Sales Dataset</strong> order is being processed.
        </p>

        <div class="bg-white/5 border border-white/10 rounded-xl p-6 mb-8 text-left">
          <h2 class="font-headline font-bold text-white mb-3">📬 What happens next?</h2>
          <ol class="text-sm text-gray-400 space-y-3">
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">1.</span>
              <span>Check your email inbox (the one you used at checkout).</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">2.</span>
              <span>You'll receive an email from Thalux AI with a download link.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">3.</span>
              <span>Click the link within 24 hours to download your CSV file.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-amber-400 font-bold shrink-0">4.</span>
              <span>Import into your CRM and start prospecting! 🚀</span>
            </li>
          </ol>
        </div>

        <div class="bg-amber-500/5 border border-amber-500/20 rounded-xl p-4 mb-8">
          <p class="text-sm text-amber-300">
            ⏱️ <strong>Didn't receive an email?</strong> Check your spam folder or contact
            <a href="mailto:support@thalux.ai" class="underline">support@thalux.ai</a>
          </p>
        </div>

        <a href="/data/fdic-bankintel" class="inline-block text-sm text-gray-500 hover:text-gray-300 transition-colors">
          ← Back to product page
        </a>
      </div>
    </main>

    <script>
      // Auto-refresh for subscription purchases
      // If this page was reached after Stripe redirect, check for session_id
      const urlParams = new URLSearchParams(window.location.search);
      const sessionId = urlParams.get('session_id');
      if (sessionId) {
        console.log('Stripe session completed:', sessionId);
        // The webhook will handle fulfillment asynchronously.
        // This page just confirms the purchase was recorded.
      }
    </script>
  </body>
</html>