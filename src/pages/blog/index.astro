---
import Layout from '../../layouts/Layout.astro';

const siteUrl = 'https://thalux.ai';
const pageTitle = 'Blog — Thalux AI';

// Blog posts registry — add new posts here
const posts = [
  {
    slug: 'samgov-migration-guide',
    title: 'How to Replace Your FPDS ATOM Feed with the SAM.gov Contract Awards API',
    description: 'A technical migration guide for federal contractors facing the July 31, 2026 ATOM feed retirement.',
    date: '2026-07-20',
    tags: ['Migration Guide', 'Deadline Jul 31, 2026'],
    readTime: '10 min',
  },
  {
    slug: 'atom-feed-retirement',
    title: 'FPDS ATOM Feed Retirement — What Federal Contractors Need to Know',
    description: 'The FPDS ATOM feed is being retired. Here\'s what changes, what doesn\'t, and how to prepare.',
    date: '2026-07-20',
    tags: ['Announcement', 'Deadline Jul 31, 2026'],
    readTime: '8 min',
  },
];

// Sort by date descending
posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title={pageTitle}>
  <!-- Blog Header -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-8">
    <h1 class="font-['Manrope'] text-3xl md:text-5xl font-extrabold leading-tight tracking-tight text-[#2D2D2D] mb-4">
      Thalux <span class="text-[#E5B73C]">Blog</span>
    </h1>
    <p class="text-lg text-[#333] leading-relaxed">
      Government data intelligence, procurement insights, and the future of federal contracting — from the team at Thalux AI.
    </p>
  </section>

  <!-- Blog List -->
  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="space-y-6">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="block bg-white rounded-xl border border-[#DED8D0] p-8 hover:shadow-lg hover:border-[#E5B73C] transition-all duration-200 group">
          <div class="flex flex-wrap gap-2 mb-3">
            {post.tags.map((tag) => (
              <span class="inline-block bg-[rgba(229,183,60,0.12)] text-[#E5B73C] font-['Manrope'] font-bold text-xs px-3 py-1.5 rounded-full uppercase tracking-wider">
                {tag}
              </span>
            ))}
          </div>
          <h2 class="font-['Manrope'] text-xl font-bold text-[#2D2D2D] group-hover:text-[#E5B73C] transition-colors mb-2">
            {post.title}
          </h2>
          <p class="text-[#555] text-sm leading-relaxed mb-3">
            {post.description}
          </p>
          <div class="flex items-center gap-3 text-xs text-[#999]">
            <time datetime={post.date}>{post.date}</time>
            <span>·</span>
            <span>{post.readTime}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>