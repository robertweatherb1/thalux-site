---
import Layout from '../layouts/Layout.astro';
const pageTitle = 'Client Portal';
---

<Layout title={pageTitle}>
  <section class="max-w-6xl mx-auto px-6 pt-28 pb-20">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="font-['Manrope'] text-3xl md:text-4xl font-extrabold text-[#2D2D2D] mb-4">
        Client Billing Portal
      </h1>
      <p class="text-[#666] text-lg leading-relaxed mb-8">
        Access your invoices, payment history, update payment methods, and download receipts — all in one place.
      </p>

      <div class="bg-white rounded-xl p-8 border border-[#DED8D0] mb-10">
        <div class="font-['Manrope'] font-bold text-xl text-[#2D2D2D] mb-6">Sign In to the Portal</div>
        
        <form method="GET" action="/api/portal" class="space-y-4">
          <div class="text-left">
            <label class="block text-sm font-medium text-gray-600 mb-1">Customer ID</label>
            <input type="text" name="customer_id" placeholder="e.g. cus_XXXXXXXXXXXXXXXXXXX" 
              class="w-full px-4 py-3 border border-[#DED8D0] rounded-lg text-sm focus:outline-none focus:border-[#E5B73C] focus:ring-1 focus:ring-[#E5B73C] transition-colors"
              required>
          </div>
          <button type="submit" 
            class="bg-[#E5B73C] text-white px-8 py-3 rounded-lg font-['Manrope'] font-bold text-sm hover:bg-[#CDA333] transition-colors w-full">
            Access Your Portal
          </button>
        </form>

        <p class="text-xs text-gray-400 mt-4">
          Your Customer ID was included in your onboarding email. 
          Need help finding it? <a href="tel:+17175370566" class="text-[#E5B73C] hover:underline">Call (717) 537-0566</a>
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 text-left">
        <div class="bg-white rounded-xl p-6 border border-[#DED8D0]">
          <div class="font-['Manrope'] font-bold text-[#2D2D2D] mb-2">Invoices</div>
          <p class="text-sm text-[#666]">View and download all invoices. Each invoice includes a detailed breakdown of services rendered for that billing period.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-[#DED8D0]">
          <div class="font-['Manrope'] font-bold text-[#2D2D2D] mb-2">Payment History</div>
          <p class="text-sm text-[#666]">See all payments, update your default payment method, and download receipts for your records.</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-[#DED8D0]">
          <div class="font-['Manrope'] font-bold text-[#2D2D2D] mb-2">Account Details</div>
          <p class="text-sm text-[#666]">Update your billing address, phone number, and contact information associated with your account.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>